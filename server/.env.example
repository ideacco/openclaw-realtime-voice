HOST=0.0.0.0
PORT=8080
VOICE_GATEWAY_TOKEN=dev-token
VOICE_IDLE_TIMEOUT_MS=0

SPEECH_API_KEY=
ASR_PROVIDER=aliyun
ASR_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ASR_MODEL=fun-asr-realtime-2026-02-28
ASR_LANGUAGE=zh
ASR_SAMPLE_RATE=16000
TTS_PROVIDER=aliyun
TTS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
TTS_MODEL=qwen3-tts-instruct-flash-realtime
TTS_VOICE=Bunny
TTS_FORMAT=pcm
TTS_SAMPLE_RATE=24000
TTS_MODE=server_commit

# Optional: direct gateway mode for standalone web debugging.
# Keep empty for normal channel-plugin mode (OpenClaw is driven by the plugin, not by server direct HTTP calls).
OPENCLAW_GATEWAY_BASE_URL=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=main
# Advanced: normally keep default.
OPENCLAW_REQUEST_MODEL=openclaw
OPENCLAW_CHAT_PATH=/v1/chat/completions
OPENCLAW_TIMEOUT_MS=45000
# OPENCLAW_SYSTEM_PROMPT=You are OpenClaw voice assistant.

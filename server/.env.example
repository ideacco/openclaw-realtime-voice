HOST=0.0.0.0
PORT=8080
VOICE_GATEWAY_TOKEN=dev-token
VOICE_IDLE_TIMEOUT_MS=60000

SPEECH_API_KEY=
ASR_PROVIDER=mock
ASR_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ASR_MODEL=fun-asr-realtime-2026-02-28
ASR_LANGUAGE=zh
ASR_SAMPLE_RATE=16000
TTS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
TTS_MODEL=qwen3-tts-instruct-flash-realtime
TTS_VOICE=Bunny
TTS_FORMAT=pcm
TTS_SAMPLE_RATE=24000
TTS_MODE=server_commit
MOCK_TTS=true
# 兼容旧配置：当 ASR_PROVIDER 未设置时，MOCK_ASR=true -> mock, MOCK_ASR=false -> aliyun
MOCK_ASR=true
